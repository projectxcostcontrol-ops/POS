# Local development only. In production (Render), the Loyverse token and
# sync interval are set from the app's Settings page instead and stored in
# Firestore - see DEPLOY.md.

# Optional fallback used only if no token has been saved via the Settings
# page yet (handy for local dev so you don't have to click through the UI
# every time you wipe the emulator's data).
LOYVERSE_ACCESS_TOKEN=your_loyverse_personal_access_token_here

# Firebase - for local dev, use the emulator (no real project needed):
USE_FIREBASE_EMULATOR=true
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
# Must match VITE_FIREBASE_PROJECT_ID in the frontend's .env. A token minted
# for one project id is rejected by an admin SDK initialized with another -
# it surfaces at login as an "aud" claim error, which doesn't obviously
# point at this setting.
FIREBASE_PROJECT_ID=pos-app-dev

# For a real Firebase project instead, set USE_FIREBASE_EMULATOR=false and
# either of:
#   FIREBASE_CREDENTIALS_JSON=<paste the whole service-account JSON as one line>
#   FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json
# With real credentials the project id comes from the service account
# itself, so FIREBASE_PROJECT_ID above is ignored - and the two emulator
# host variables must be UNSET, or tokens get verified against a local
# emulator that isn't running.

# Optional fallback sync interval (seconds) - overridden by whatever's set
# on the Settings page once you've saved one there.
SYNC_INTERVAL_SECONDS=300
# (Docker deploys read the same env vars above - set them in your
# platform's dashboard, e.g. Koyeb/Northflank environment variables.)

# --- AI invoice reading (step 4.1) ---
# Get a free key at https://aistudio.google.com/apikey - no credit card needed.
# Free tier is comfortably enough for a restaurant's delivery volume.
# Note: Google may use free-tier data for model training; switch to a paid
# tier or another provider if that matters for your invoices.
GEMINI_API_KEY=
# Optional - defaults to gemini-3.5-flash
GEMINI_MODEL=
# --- Receipt image storage (step 4.5) ---
FIREBASE_STORAGE_BUCKET=

# Our own back office (/admin). Comma-separated emails. Anyone NOT listed
# here gets a 404 on the admin endpoints - it isn't a role in the database,
# so no amount of tampering with a business's own records can grant it.
# Leave empty to disable the admin page entirely.
SUPER_ADMIN_EMAILS=
