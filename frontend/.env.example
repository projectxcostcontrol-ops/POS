# Copy to .env and fill in. Values here are NOT secrets - they're visible
# in the built bundle. Real protection comes from Firebase Auth plus the
# backend's role and tenant checks.

# --- Local development (Firebase emulator) -------------------------------
# The emulator ignores the API key, so dummy values are fine. The project
# id must match the backend's FIREBASE_PROJECT_ID or login fails on the
# token's "aud" claim.
# VITE_FIREBASE_API_KEY=demo-key
# VITE_FIREBASE_AUTH_DOMAIN=localhost
# VITE_FIREBASE_PROJECT_ID=pos-app-dev
# VITE_USE_AUTH_EMULATOR=true
# VITE_API_URL=http://127.0.0.1:8000

# --- Production ----------------------------------------------------------
# From Firebase Console -> Project Settings -> General -> Your apps -> Web.
# Leave VITE_USE_AUTH_EMULATOR OUT entirely (not "false") in production.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_API_URL=https://your-backend-url
